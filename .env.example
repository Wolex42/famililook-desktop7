# Local development
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173
PORT=8030
DESKTOP3_URL=http://localhost:8008
DESKTOP3_TIMEOUT=30
ROOM_IDLE_TIMEOUT_SECONDS=1800
MAX_ROOMS=5000

# Cross-app tier gating (shared secret with desktop3)
# Must match MATCH_TIER_SECRET in desktop3's .env
# Generate: openssl rand -hex 32
MATCH_TIER_SECRET=

# Hetzner production (uncomment + set):
# ALLOWED_ORIGINS=https://your-domain.app,https://www.your-domain.app
# DESKTOP3_URL=http://backend:8008
